# Frontend env. Copy to `.env.local`. All optional for local dev.

# Backend base URL (defaults to http://localhost:8000 if unset).
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ElevenLabs voice for Maya (optional — falls back to the browser's built-in
# speech synthesis when unset, so the lab still talks).
# ELEVENLABS_API_KEY=
# ELEVEN_VOICE_INTERVIEWER=
