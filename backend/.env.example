# Backend env. Copy to `backend/.env`. All optional.

# Use a live LLM for Maya's questions/scoring. Without it, the lab runs the
# deterministic scripted interviewer (fully functional, just not generative).
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Store backend: "memory" (default) or "supabase" (not needed for the demo).
# VNEXT_STORE=memory

# Extra CORS origins (comma-separated) beyond http://localhost:3000.
# CORS_ORIGINS=
